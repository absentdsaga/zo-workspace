sprites-32x32&amp;intent=community" class="vote_up_btn vote_btn"><svg role="img" viewBox="0 0 24 24" aria-hidden version="1.1" height="20" width="20" class="svgicon icon_vote_up"><polygon points="2 18 12 6 22 18" /></svg></a> <a title="Vote down" data-register_action="community_vote" href="https://itch.io/login?return_to=https%3A%2F%2Fpipoya.itch.io%2Fpipoya-free-rpg-character-sprites-32x32&amp;intent=community" class="vote_down_btn vote_btn"><svg role="img" viewBox="0 0 24 24" aria-hidden version="1.1" height="20" width="20" class="svgicon icon_vote_down"><polygon points="2 6 12 18 22 6" /></svg></a></div><a href="https://itch.io/profile/pipoya" class="avatar_container"><div style="background-image: url(https://img.itch.zone/aW1hZ2UyL3VzZXIvOTEyMDE1LzEyMjg1ODgucG5n/25x25%23/ElHQpB.png)" class="post_avatar"></div></a><div class="post_header"><span class="post_author"><a href="https://itch.io/profile/pipoya">Pipoya</a></span><span title="2022-03-12 04:43:18" class="post_date"><a href="https://itch.io/post/5588809">3 years ago</a></span><span class="vote_counts"><span class="upvotes">(+1)</span></span></div><div class="post_content"><div dir="auto" class="post_body user_formatted"><p>Thank you for your comment.</p>
<p>Yes, it can be used with RPG Maker MZ and others. However, please note that the characters are smaller (32x32) than the standard size (48x48) of RPG Maker MZ.</p></div><div class="post_footer"><a data-register_action="community_reply" href="https://itch.io/login?return_to=https%3A%2F%2Fpipoya.itch.io%2Fpipoya-free-rpg-character-sprites-32x32&amp;intent=community" class="post_action reply_btn">Reply</a></div></div></div></div><div class="community_post_replies"><div data-post="{&quot;id&quot;:5589320,&quot;user_id&quot;:2029948}" class="community_post has_vote_column is_reply has_replies" id="post-5589320"><div class="post_grid"><div class="post_votes"><a title="Vote up" data-register_action="community_vote" href="https://itch.io/login?return_to=https%3A%2F%2Fpipoya.itch.io%2Fpipoya-free-rpg-character-sprites-32x32&amp;intent=community" class="vote_up_btn vote_btn"><svg role="img" viewBox="0 0 24 24" aria-hidden version="1.1" height="20" width="20" class="svgicon icon_vote_up"><polygon points="2 18 12 6 22 18" /></svg></a> <a title="Vote down" data-register_action="community_vote" href="https://itch.io/login?return_to=https%3A%2F%2Fpipoya.itch.io%2Fpipoya-free-rpg-character-sprites-32x32&amp;intent=community" class="vote_down_btn vote_btn"><svg role="img" viewBox="0 0 24 24" aria-hidden version="1.1" height="20" width="20" class="svgicon icon_vote_down"><polygon points="2 6 12 18 22 6" /></svg></a></div><a href="https://itch.io/profile/restartmv" class="avatar_container"><div style="background-image: url(/static/images/frog-gold.png)" class="post_avatar"></div></a><div class="post_header"><span class="post_author"><a href="https://itch.io/profile/restartmv">RestartMV</a></span><span title="2022-03-12 08:08:33" class="post_date"><a href="https://itch.io/post/5589320">3 years ago</a></span><span class="vote_counts"></span></div><div class="post_content"><div dir="auto" class="post_body user_formatted"><p>According to their twitter MZ is getting an update soon which will allow for 32x32 tilesets!</p><p><a href="https://twitter.com/RPGMakerSeries/status/1493064956937265156?" referrerpolicy="origin" rel="nofollow noopener">https://twitter.com/RPGMakerSeries/status/1493064956937265156?</a><br></p></div><div class="post_footer"><a data-register_action="community_reply" href="https://itch.io/login?return_to=https%3A%2F%2Fpipoya.itch.io%2Fpipoya-free-rpg-character-sprites-32x32&amp;intent=community" class="post_action reply_btn">Reply</a></div></div></div></div><div class="community_post_replies"><div data-post="{&quot;id&quot;:5589394,&quot;user_id&quot;:912015}" class="community_post has_vote_column is_reply" id="post-5589394"><div class="post_grid"><div class="post_votes"><a title="Vote up" data-register_action="community_vote" href="https://itch.io/login?return_to=https%3A%2F%2Fpipoya.itch.io%2Fpipoya-free-rpg-character-sprites-32x32&amp;intent=community" class="vote_up_btn vote_btn"><svg role="img" viewBox="0 0 24 24" aria-hidden version="1.1" height="20" width="20" class="svgicon icon_vote_up"><polygon points="2 18 12 6 22 18" /></svg></a> <a title="Vote down" data-register_action="community_vote" href="https://itch.io/login?return_to=https%3A%2F%2Fpipoya.itch.io%2Fpipoya-free-rpg-character-sprites-32x32&amp;intent=community" class="vote_down_btn vote_btn"><svg role="img" viewBox="0 0 24 24" aria-hidden version="1.1" height="20" width="20" class="svgicon icon_vote_down"><polygon points="2 6 12 18 22 6" /></svg></a></div><a href="https://itch.io/profile/pipoya" class="avatar_container"><div style="background-image: url(https://img.itch.zone/aW1hZ2UyL3VzZXIvOTEyMDE1LzEyMjg1ODgucG5n/25x25%23/ElHQpB.png)" class="post_avatar"></div></a><div class="post_header"><span class="post_author"><a href="https://itch.io/profile/pipoya">Pipoya</a></span><span title="2022-03-12 08:53:32" class="post_date"><a href="https://itch.io/post/5589394">3 years ago</a></span><span class="vote_counts"><span class="upvotes">(+1)</span></span></div><div class="post_content"><div dir="auto" class="post_body user_formatted"><p>I look forward to seeing that feature implemented!</p>
<p>As for the size of the character sprites, I don&#x27;t think there were any size restrictions even today, so I think 32x32 could have been used. I was concerned that if they were to be used with 48x48 size ones, they would be uncomfortable and we would need to standardize the size of one or the other.</p></div><div class="post_footer"><a data-register_action="community_reply" href="https://itch.io/login?return_to=https%3A%2F%2Fpipoya.itch.io%2Fpipoya-free-rpg-character-sprites-32x32&amp;intent=community" class="post_action reply_btn">Reply</a></div></div></div></div></div></div></div><div data-post="{&quot;id&quot;:5552982,&quot;user_id&quot;:1565736}" class="community_post has_vote_column has_replies" id="post-5552982"><div class="post_grid"><div class="post_votes"><a title="Vote up" data-register_action="community_vote" href="https://itch.io/login?return_to=https%3A%2F%2Fpipoya.itch.io%2Fpipoya-free-rpg-character-sprites-32x32&amp;intent=community" class="vote_up_btn vote_btn"><svg role="img" viewBox="0 0 24 24" aria-hidden version="1.1" height="20" width="20" class="svgicon icon_vote_up"><polygon points="2 18 12 6 22 18" /></svg></a> <a title="Vote down" data-register_action="community_vote" href="https://itch.io/login?return_to=https%3A%2F%2Fpipoya.itch.io%2Fpipoya-free-rpg-character-sprites-32x32&amp;intent=community" class="vote_down_btn vote_btn"><svg role="img" viewBox="0 0 24 24" aria-hidden version="1.1" height="20" width="20" class="svgicon icon_vote_down"><polygon points="2 6 12 18 22 6" /></svg></a></div><a href="https://itch.io/profile/rdchris" class="avatar_container"><div style="background-image: url(https://img.itch.zone/aW1nLzEwMDAyMTUyLmpwZw==/25x25%23/ijPyPE.jpg)" class="post_avatar"></div></a><div class="post_header"><span class="post_author"><a href="https://itch.io/profile/rdchris">rdchris</a></span><span title="2022-03-06 15:24:06" class="post_date"><a href="https://itch.io/post/5552982">3 years ago</a></span><span class="vote_counts"></span></div><div class="post_content"><div dir="auto" class="post_body user_formatted"><p>This is totally amazing!!!&nbsp;<br><br>Is there any chance it could get upscaled to 64x64/128x128 easily?&nbsp;</p></div><div class="post_footer"><a data-register_action="community_reply" href="https://itch.io/login?return_to=https%3A%2F%2Fpipoya.itch.io%2Fpipoya-free-rpg-character-sprites-32x32&amp;intent=community" class="post_action reply_btn">Reply</a></div></div></div></div><div class="community_post_replies top_level_replies"><div data-post="{&quot;id&quot;:5557647,&quot;user_id&quot;:912015}" class="community_post has_vote_column is_reply deleted is_deleted disabled" id="post-5557647"><div class="post_grid"><div class="post_votes"><a title="Vote up" data-register_action="community_vote" href="https://itch.io/login?return_to=https%3A%2F%2Fpipoya.itch.io%2Fpipoya-free-rpg-character-sprites-32x32&amp;intent=community" class="vote_up_btn vote_btn"><svg role="img" viewBox="0 0 24 24" aria-hidden version="1.1" height="20" width="20" class="svgicon icon_vote_up"><polygon points="2 18 12 6 22 18" /></svg></a> <a title="Vote down" data-register_action="community_vote" href="https://itch.io/login?return_to=https%3A%2F%2Fpipoya.itch.io%2Fpipoya-free-rpg-character-sprites-32x32&amp;intent=community" class="vote_down_btn vote_btn"><svg role="img" viewBox="0 0 24 24" aria-hidden version="1.1" height="20" width="20" class="svgicon icon_vote_down"><polygon points="2 6 12 18 22 6" /></svg></a></div><div class="avatar_container"><div style="background-image: url(https://static.itch.io/images/frog-sad.svg)" class="post_avatar"></div></div><div class="post_header"><span class="post_author"><strong class="name_placeholder">Deleted post</strong></span><span title="2022-03-07 04:22:30" class="post_date"><a href="https://itch.io/post/5557647">3 years ago</a></span></div><div class="post_content"><div class="post_body"><em class="deleted_message">Deleted <span class="2022-03-07 04:25:10">3 years ago</span></em></div><div class="post_footer"><a data-register_action="community_reply" href="https://itch.io/login?return_to=https%3A%2F%2Fpipoya.itch.io%2Fpipoya-free-rpg-character-sprites-32x32&amp;intent=community" class="post_action reply_btn">Reply</a></div></div></div></div><div data-post="{&quot;id&quot;:5557656,&quot;user_id&quot;:912015}" class="community_post has_vote_column is_reply has_replies" id="post-5557656"><div class="post_grid"><div class="post_votes"><a title="Vote up" data-register_action="community_vote" href="https://itch.io/login?return_to=https%3A%2F%2Fpipoya.itch.io%2Fpipoya-free-rpg-character-sprites-32x32&amp;intent=community" class="vote_up_btn vote_btn"><svg role="img" viewBox="0 0 24 24" aria-hidden version="1.1" height="20" width="20" class="svgicon icon_vote_up"><polygon points="2 18 12 6 22 18" /></svg></a> <a title="Vote down" data-register_action="community_vote" href="https://itch.io/login?return_to=https%3A%2F%2Fpipoya.itch.io%2Fpipoya-free-rpg-character-sprites-32x32&amp;intent=community" class="vote_down_btn vote_btn"><svg role="img" viewBox="0 0 24 24" aria-hidden version="1.1" height="20" width="20" class="svgicon icon_vote_down"><polygon points="2 6 12 18 22 6" /></svg></a></div><a href="https://itch.io/profile/pipoya" class="avatar_container"><div style="background-image: url(https://img.itch.zone/aW1hZ2UyL3VzZXIvOTEyMDE1LzEyMjg1ODgucG5n/25x25%23/ElHQpB.png)" class="post_avatar"></div></a><div class="post_header"><span class="post_author"><a href="https://itch.io/profile/pipoya">Pipoya</a></span><span title="2022-03-07 04:24:53" class="post_date"><a href="https://itch.io/post/5557656">3 years ago</a></span><span class="vote_counts"><span class="upvotes">(+1)</span></span></div><div class="post_content"><div dir="auto" class="post_body user_formatted"><p></p>
<p>Thank you for your comment.</p>
<p>If you want something that upscales pixels in fine detail rather than simply upscaling, this is the way to go.&nbsp;English is also supported.</p>
<p>ぴくせる すけゐらぁ<br><a href="https://irokaru.github.io/pixel-scaler/" referrerpolicy="origin" rel="nofollow noopener">https://irokaru.github.io/pixel-scaler/</a></p>
<p>ぴくせる すけゐらぁ - ののの茶屋 BOOTH支店 - BOOTH<br><a href="https://nononotyaya.booth.pm/items/2517679" referrerpolicy="origin" rel="nofollow noopener">https://nononotyaya.booth.pm/items/2517679</a></p><p>I am considering adopting it in a program I have created, but I have no plans to add that functionality at this time.</p></div><div class="post_footer"><a data-register_action="community_reply" href="https://itch.io/login?return_to=https%3A%2F%2Fpipoya.itch.io%2Fpipoya-free-rpg-character-sprites-32x32&amp;intent=community" class="post_action reply_btn">Reply</a></div></div></div></div><div class="community_post_replies"><div data-post="{&quot;id&quot;:5559381,&quot;user_id&quot;:912015}" class="community_post has_vote_column is_reply" id="post-5559381"><div class="post_grid"><div class="post_votes"><a title="Vote up" data-register_action="community_vote" href="https://itch.io/login?return_to=https%3A%2F%2Fpipoya.itch.io%2Fpipoya-free-rpg-character-sprites-32x32&amp;intent=community" class="vote_up_btn vote_btn"><svg role="img" viewBox="0 0 24 24" aria-hidden version="1.1" height="20" width="20" class="svgicon icon_vote_up"><polygon points="2 18 12 6 22 18" /></svg></a> <a title="Vote down" data-register_action="community_vote" href="https://itch.io/login?return_to=https%3A%2F%2Fpipoya.itch.io%2Fpipoya-free-rpg-character-sprites-32x32&amp;intent=community" class="vote_down_btn vote_btn"><svg role="img" viewBox="0 0 24 24" aria-hidden version="1.1" height="20" width="20" class="svgicon icon_vote_down"><polygon points="2 6 12 18 22 6" /></svg></a></div><a href="https://itch.io/profile/pipoya" class="avatar_container"><div style="background-image: url(https://img.itch.zone/aW1hZ2UyL3VzZXIvOTEyMDE1LzEyMjg1ODgucG5n/25x25%23/ElHQpB.png)" class="post_avatar"></div></a><div class="post_header"><span class="post_author"><a href="https://itch.io/profile/pipoya">Pipoya</a></span><span title="2022-03-07 11:51:53" class="post_date"><a href="https://itch.io/post/5559381">3 years ago</a></span><span class="vote_counts"></span></div><div class="post_content"><div dir="auto" class="post_body user_formatted"><p>Sorry. Perhaps you meant a simple upscale? Implementation was easy, so I added it. In the next update.</p><p><img src="https://img.itch.zone/aW1nLzgzNDQ2MzgucG5n/original/bH2OT5.png" loading="lazy"></p></div><div class="post_footer"><a data-register_action="community_reply" href="https://itch.io/login?return_to=https%3A%2F%2Fpipoya.itch.io%2Fpipoya-free-rpg-character-sprites-32x32&amp;intent=community" class="post_action reply_btn">Reply</a></div></div></div></div></div></div><div data-post="{&quot;id&quot;:5421577,&quot;user_id&quot;:3126920}" class="community_post has_vote_column has_replies" id="post-5421577"><div class="post_grid"><div class="post_votes"><a title="Vote up" data-register_action="community_vote" href="https://itch.io/login?return_to=https%3A%2F%2Fpipoya.itch.io%2Fpipoya-free-rpg-character-sprites-32x32&amp;intent=community" class="vote_up_btn vote_btn"><svg role="img" viewBox="0 0 24 24" aria-hidden version="1.1" height="20" width="20" class="svgicon icon_vote_up"><polygon points="2 18 12 6 22 18" /></svg></a> <a title="Vote down" data-register_action="community_vote" href="https://itch.io/login?return_to=https%3A%2F%2Fpipoya.itch.io%2Fpipoya-free-rpg-character-sprites-32x32&amp;intent=community" class="vote_down_btn vote_btn"><svg role="img" viewBox="0 0 24 24" aria-hidden version="1.1" height="20" width="20" class="svgicon icon_vote_down"><polygon points="2 6 12 18 22 6" /></svg></a></div><a href="https://itch.io/profile/slaziel" class="avatar_container"><div style="background-image: url(https://img.itch.zone/aW1nLzEyODI2NzU1LnBuZw==/25x25%23/8WS%2FTL.png)" class="post_avatar"></div></a><div class="post_header"><span class="post_author"><a href="https://itch.io/profile/slaziel">Slaziel</a></span><span title="2022-02-20 20:42:34" class="post_date"><a href="https://itch.io/post/5421577">3 years ago</a></span><span class="vote_co