# Polymarket Trading Bot Configuration
# Copy this file to .env and fill in your details

# Polymarket API Credentials (for WebSocket real-time data)
# Get these from: https://polymarket.com → Account → API Settings
POLYMARKET_API_KEY=your_api_key_here
POLYMARKET_API_SECRET=your_api_secret_here
POLYMARKET_API_PASSPHRASE=your_passphrase_here

# Required: Your Ethereum private key (must have USDC on Polygon)
# Get this from MetaMask: Settings → Security & Privacy → Reveal Private Key
# IMPORTANT: Never share this key or commit it to version control
POLYMARKET_PRIVATE_KEY=0x1234567890abcdef1234567890abcdef1234567890abcdef1234567890abcdef

# Optional: Separate funder address if using different wallet for gas
# POLYMARKET_FUNDER=0x...

# Optional: Telegram bot token for trade alerts (advanced)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Safety: Backup your private key securely
# Store in password manager
# Never share with anyone
# This wallet should only have trading funds (start with $100-500)
